local function getClosestToMouse()
    local char = LocalPlayer.Character
    if not char then return nil end

    local myRoot = getRoot(char)
    if not myRoot then return nil end

    local bestTarget = nil
    local bestDist = math.huge

    local function tryCandidate(model)
        if not model then return end
        if not model:IsA("Model") then return end
        if model == char then return end

        -- must have humanoid
        local hum = model:FindFirstChildWhichIsA("Humanoid")
        if not hum then return end
        if hum.Health <= 0 then return end

        -- must have root
        local root = getRoot(model)
        if not root then return end

        -- must have animator (prevents map parts)
        local animator = hum:FindFirstChildOfClass("Animator")
        if not animator then return end

        -- must be visible
        local pos, visible = Camera:WorldToViewportPoint(root.Position)
        if not visible then return end

        -- must be in range
        local distWorld = (root.Position - myRoot.Position).Magnitude
        if distWorld > LOCK_RANGE then return end

        -- pixel distance to mouse
        local distScreen = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude

        if distScreen < bestDist then
            bestDist = distScreen
            bestTarget = model
        end
    end

    -- players
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            tryCandidate(plr.Character)
        end
    end

    -- npcs in workspace.Living
    local living = workspace:FindFirstChild("Living")
    if living then
        for _, npc in ipairs(living:GetChildren()) do
            tryCandidate(npc)
        end
    end

    return bestTarget
end


