-- Hold F, click right mouse button, then release F
-- Hold F, click right mouse button, then release F
-- If alreadyHeld==true, assumes F is already held down and will only perform the click+release
local function holdF_then_m2(alreadyHeld)
    local VIM = VirtualInput
    local viewport = Camera.ViewportSize

    -- use center of screen (fixes missed clicks)
    local x = viewport.X / 2
    local y = viewport.Y / 2

    if not alreadyHeld then
        VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)

        -- make sure F is actually held
        task.wait(0.2)
        task.wait() -- extra frame (VERY IMPORTANT)
    end

    -- right click (longer = more consistent)
    VIM:SendMouseButtonEvent(x, y, 1, true, game, 0)
    task.wait(0.03)
    VIM:SendMouseButtonEvent(x, y, 1, false, game, 0)

    -- slight delay before releasing F
    task.wait(0.02)

    VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
end

local function press_R_plus_F(alreadyHeld)
    local VIM = VirtualInput
    if not alreadyHeld then
        VIM:SendKeyEvent(true, Enum.KeyCode.R, false, game)
        VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        task.wait(0.02)
    end

    -- short hold to ensure the game registers the combo
    task.wait(0.01)

    VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
    VIM:SendKeyEvent(false, Enum.KeyCode.R, false, game)

    -- left click 0.5s after RF releases
    task.spawn(function()
        task.wait(0.2)
        local viewport = Camera.ViewportSize
        local x = viewport.X / 2
        local y = viewport.Y / 2
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.02)
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end


-- Detect whether any descendant named "Highlight" exists under the local player's character
local function hasHighlight()
    local char = LocalPlayer and LocalPlayer.Character
    if not char then return false end
    return char:FindFirstChild("Highlight", true) ~= nil
end


-- Hold F, wait a short delay, left-click, then release F
local function holdF_then_lclick(alreadyHeld, leftDelay)
    leftDelay = tonumber(leftDelay) or 0.2
    local VIM = VirtualInput
    local viewport = Camera.ViewportSize

    -- use center of screen for consistent clicks
    local x = viewport.X / 2
    local y = viewport.Y / 2

    if not alreadyHeld then
        VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)

        -- ensure F is actually held
        task.wait(0.03)
        task.wait()
    end

    -- wait the requested delay then left-click
    task.wait(leftDelay)
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.02)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)

    -- slight delay before releasing F
    task.wait(0.02)
    VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
end


local function hookAnimationsAuto(model)
    local hum = model:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end

    local animator = hum:FindFirstChildOfClass("Animator")
        or Instance.new("Animator", hum)

        -- 🔥 If the target dies, disconnect animations IMMEDIATELY
        hum.Died:Connect(function()
            fullUnlockCleanup()
        end)

    createBillboard(model)

    ----------------------------------------------------------------
    -- F SYSTEM (works for players and NPCs)
    ----------------------------------------------------------------
    genv.LOCK_ANIMCONN_F =
        animator.AnimationPlayed:Connect(function(track)

            local id = tostring(track.Animation.AnimationId or ""):match("%d+")
            if not id then return end

            -- 🔥 UNTRACKED ANIMATION LOGGING (includes RF category)
            if not LOOKUP_F[id] and not LOOKUP_F_BEFORE[id] and not CUSTOM_DELAY_MAP[id] and not CUSTOM_BEFORE_MAP[id]
                and not LOOKUP_RF[id] and not LOOKUP_RF_BEFORE[id] and not CUSTOM_DELAY_RF_MAP[id] and not CUSTOM_BEFORE_RF_MAP[id] then
                logUntrackedAnimation(id, model)
            end

            -- Only continue if this animation is tracked in either F or RF categories
            if not (LOOKUP_F[id] or LOOKUP_F_BEFORE[id] or CUSTOM_DELAY_MAP[id] or CUSTOM_BEFORE_MAP[id]
                or LOOKUP_RF[id] or LOOKUP_RF_BEFORE[id] or CUSTOM_DELAY_RF_MAP[id] or CUSTOM_BEFORE_RF_MAP[id]) then
                return
            end

            -- FIRST: handle before-end category (press F or RF some seconds BEFORE anim ends)
            if LOOKUP_F_BEFORE[id] or CUSTOM_BEFORE_MAP[id] or LOOKUP_RF_BEFORE[id] or CUSTOM_BEFORE_RF_MAP[id] then
                local isRF = (LOOKUP_RF[id] or LOOKUP_RF_BEFORE[id] or CUSTOM_DELAY_RF_MAP[id] or CUSTOM_BEFORE_RF_MAP[id])
                local beforeDelays = isRF and getBeforeDelayRF(id, RF_BEFORE_DEFAULT) or getBeforeDelay(id, F_BEFORE_DEFAULT)
                if type(beforeDelays) ~= "table" then beforeDelays = { beforeDelays } end

                -- EARLY DISTANCE + GRACE RANGE CHECK
                local extraDelayPenalty = 0
                local maxDist = CUSTOM_DISTANCE_MAP[id] or F_RANGE
                do
                    local myChar = LocalPlayer.Character
                    local myRoot = myChar and getRoot(myChar)
                    local targetRoot = model and getRoot(model)
                    if myRoot and targetRoot then
                        local distNow = (targetRoot.Position - myRoot.Position).Magnitude
                        if distNow > (maxDist + GRACE_DISTANCE) then
                            -- Beyond grace range, skip entire animation
                            return
                        elseif distNow > maxDist then
                            -- Within grace range but beyond normal; apply delay penalty
                            extraDelayPenalty = EXTENDED_RANGE_DELAY_PENALTY
                        end
                    end
                end

                for _, bd in ipairs(beforeDelays) do
                    local before = bd
                    local adjustedBefore = adjustDelay(before, true)
                    updateBillboard(id, adjustedBefore)

                    task.spawn(function()
                        local length = nil
                        pcall(function() length = track.Length end)
                        if not length then pcall(function() length = track.TimeLength end) end

                        -- Wait up to 0.1s for length to become available
                        if not length or length == 0 then
                            task.wait(0.05)
                            pcall(function() length = track.Length end)
                            if not length then pcall(function() length = track.TimeLength end) end
                        end

                        -- Fallback: if still no length, handle timed hold + action
                        if not length or length == 0 then
                            -- start holding slightly earlier than the timed press
                            local HOLD_EARLY = 0.05
                            local toWait = adjustedBefore - HOLD_EARLY + extraDelayPenalty
                            if toWait > 0 then task.wait(toWait) end

                            if genv.CURRENT_LOCKED_PLAYER ~= model then return end
                            local myChar = LocalPlayer.Character
                            if not myChar then return end
                            local myRoot = getRoot(myChar)
                            local targetRoot = getRoot(model)
                            if not myRoot or not targetRoot then return end
                            local maxDist = (isRF and CUSTOM_DISTANCE_MAP[id]) or CUSTOM_DISTANCE_MAP[id] or F_RANGE
                            local dist = (targetRoot.Position - myRoot.Position).Magnitude
                            local highlightPresent = hasHighlight()
                            if dist <= (maxDist + GRACE_DISTANCE) then
                                if isRF then
                                    -- hold R+F briefly then release
                                    press_R_plus_F()
                                else
                                    -- If a Highlight exists on our character, press F then left-click
                                    if highlightPresent then
                                        holdF_then_lclick(false, 0.25)
                                    else
                                        -- hold F then perform right-click and release
                                        holdF_then_m2()
                                    end
                                end
                                -- show parried label briefly
                                if genv.LOCK_PARRIED_LABEL then
                                    genv.LOCK_PARRIED_LABEL.Text = "Parried"
                                    task.spawn(function()
                                        task.wait(0.5)
                                        if genv.LOCK_PARRIED_LABEL then genv.LOCK_PARRIED_LABEL.Text = "" end
                                    end)
                                end
                            end
                            return
                        end

                        -- compute the exact target time in the animation when we want to trigger
                        -- Apply extra delay penalty if hit from beyond normal range
                        local baseTargetTime = math.max(0, length - adjustedBefore + extraDelayPenalty)
                        local HOLD_EARLY = 0.04
                        local held = false
                        local triggered = false

                        local startClock = os.clock()
                        local timeout = math.max(5, length + 5)

                        while true do
                            if genv.CURRENT_LOCKED_PLAYER ~= model then
                                if held then
                                    if isRF then
                                        VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                        VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                    else
                                        VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    end
                                end
                                return
                            end

                            local timePos = nil
                            pcall(function() timePos = track.TimePosition end)

                            local targetTime = baseTargetTime

                            if timePos then
                                if (not held) and timePos >= math.max(0, targetTime - HOLD_EARLY) then
                                    held = true
                                    if isRF then
                                        VirtualInput:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                                        VirtualInput:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                    else
                                        VirtualInput:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                    end
                                end

                                if timePos >= targetTime then
                                    triggered = true
                                    break
                                end
                            end

                            if os.clock() - startClock > timeout then
                                break
                            end

                            task.wait(0.01)
                        end

                        if not triggered then
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                            return
                        end

                        if genv.CURRENT_LOCKED_PLAYER ~= model then
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                            return
                        end

                        local myChar = LocalPlayer.Character
                        if not myChar then
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                            return
                        end
                        local myRoot = getRoot(myChar)
                        local targetRoot = getRoot(model)
                        if not myRoot or not targetRoot then
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                            return
                        end

                        local maxDist = (isRF and CUSTOM_DISTANCE_MAP[id]) or CUSTOM_DISTANCE_MAP[id] or F_RANGE
                        local dist = (targetRoot.Position - myRoot.Position).Magnitude
                        local highlightPresent = hasHighlight()
                        if dist <= (maxDist + GRACE_DISTANCE) then
                            -- perform RF or F action while keys are held, then release
                            if isRF then
                                press_R_plus_F(true)
                            else
                                if highlightPresent then
                                    holdF_then_lclick(true, 0.25)
                                else
                                    holdF_then_m2(true)
                                end
                            end
                            if genv.LOCK_PARRIED_LABEL then
                                genv.LOCK_PARRIED_LABEL.Text = "Parried"
                                task.spawn(function()
                                    task.wait(0.5)
                                    if genv.LOCK_PARRIED_LABEL then genv.LOCK_PARRIED_LABEL.Text = "" end
                                end)
                            end
                        else
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                        end
                    end)
                end

                return
            end

            -- SECOND: start-based timing (trigger at a delay from animation start)
            -- MULTIPLE DELAYS SUPPORT - supports F and RF categories
            local isRF = (LOOKUP_RF[id] or LOOKUP_RF_BEFORE[id] or CUSTOM_DELAY_RF_MAP[id] or CUSTOM_BEFORE_RF_MAP[id])
            local delays = isRF and (CUSTOM_DELAY_RF_MAP[id] or {RF_DEFAULT_DELAY}) or (CUSTOM_DELAY_MAP[id] or {F_DEFAULT_DELAY})

            for _, d in ipairs(delays) do
                local delay = adjustDelay(d)

                updateBillboard(id, delay)

                task.spawn(function()
                    if genv.CURRENT_LOCKED_PLAYER ~= model then return end

                    -- RANGE CHECK with GRACE DISTANCE + PENALTY
                    local myChar = LocalPlayer.Character
                    if not myChar then return end

                    local myRoot = getRoot(myChar)
                    local targetRoot = getRoot(model)
                    if not myRoot or not targetRoot then return end

                    local maxDist = F_RANGE
                    if not isRF and CUSTOM_DELAY_MAP[id] and CUSTOM_DISTANCE_MAP[id] then
                        maxDist = CUSTOM_DISTANCE_MAP[id]
                    elseif isRF and CUSTOM_DELAY_RF_MAP[id] and CUSTOM_DISTANCE_MAP[id] then
                        maxDist = CUSTOM_DISTANCE_MAP[id]
                    end

                    local dist = (targetRoot.Position - myRoot.Position).Magnitude
                    local extraDelayPenalty = 0
                    
                    if dist > (maxDist + GRACE_DISTANCE) then
                        -- Beyond grace range, skip this animation
                        return
                    elseif dist > maxDist then
                        -- Within grace range but beyond normal; apply delay penalty
                        extraDelayPenalty = EXTENDED_RANGE_DELAY_PENALTY
                    end

                    -- compute exact target time (seconds from the animation start)
                    local targetTime = math.max(0, delay + extraDelayPenalty)
                    local HOLD_EARLY = 0.04
                    local held = false
                    local triggered = false

                    local startClock = os.clock()
                    local timeout = math.max(3, targetTime + 3)

                    while true do
                        if genv.CURRENT_LOCKED_PLAYER ~= model then
                            if held then
                                if isRF then
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                else
                                    VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                end
                            end
                            return
                        end

                        local timePos = nil
                        pcall(function() timePos = track.TimePosition end)

                        if timePos then
                            if (not held) and timePos >= math.max(0, targetTime - HOLD_EARLY) then
                                held = true
                                if isRF then
                                    VirtualInput:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                                    VirtualInput:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                else
                                    VirtualInput:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                                end
                            end

                            if timePos >= targetTime then
                                triggered = true
                                break
                            end
                        end

                        if os.clock() - startClock > timeout then
                            break
                        end

                        task.wait(0.01)
                    end

                    if not triggered then
                        if held then
                            if isRF then
                                VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                                VirtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                            else
                                VirtualInput:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                            end
                        end
                        return
                    end

                    -- perform RF or F action while keys are held, then release
                    if isRF then
                        press_R_plus_F(true)
                    else
                        if hasHighlight() then
                            holdF_then_lclick(true, 0.2)
                        else
                            holdF_then_m2(true)
                        end
                    end

                    if genv.LOCK_PARRIED_LABEL then
                        genv.LOCK_PARRIED_LABEL.Text = "Parried"
                        task.spawn(function()
                            task.wait(0.5)
                            if genv.LOCK_PARRIED_LABEL then genv.LOCK_PARRIED_LABEL.Text = "" end
                        end)
                    end
                end)

            end

            end) -- CLOSES animator.AnimationPlayed (F SYSTEM)

end


