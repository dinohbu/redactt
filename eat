local REPORTED_UNTRACKED = {} -- prevents duplicate spam

-- (We still keep REPORTED_UNTRACKED declared for compatibility, but it's no longer used to block UI updates)

-- logUntrackedAnimation now accepts optional model to update UI for locked target
local function logUntrackedAnimation(id, model)

    -- ❗ Only send to webhook when WEBHOOK_MODE = false
    if getgenv().WEBHOOK_MODE then return end

    -- Only report once per animation id to avoid spam
    if REPORTED_UNTRACKED[id] then return end

    if EXCLUDED_UNTRACKED[id] then return end

    local animName = getAnimName(id)

    -- If animName is Unknown, try to find a player-side Animation instance and use its parent name
    if animName == "Unknown" then
        -- search players and their descendants for an Animation with this id
        for _, pl in ipairs(Players:GetPlayers()) do
            for _, desc in ipairs(pl:GetDescendants()) do
                if desc:IsA("Animation") then
                    local aid = tostring(desc.AnimationId or ""):match("%d+")
                    if aid == tostring(id) then
                        if desc.Parent then
                            animName = desc.Parent.Name
                            break
                        end
                    end
                end
            end
            if animName ~= "Unknown" then break end
        end
    end

    sendWebhook(
        "UNTRACKED ANIMATION DETECTED",
        "**Name:** " .. animName .. "\n" ..
        "**ID:** `" .. id .. "`"
    )

    -- mark reported to prevent duplicates (also prevents repeated UI updates)
    REPORTED_UNTRACKED[id] = true

    -- If this untracked animation belongs to the currently locked player, update the billboard blue label
    if model and genv.CURRENT_LOCKED_PLAYER and model == genv.CURRENT_LOCKED_PLAYER then
        if genv.LOCK_UNTRACKED_LABEL then
            genv.LOCK_UNTRACKED_LABEL.Text = animName .. " (ID: " .. id .. ")"
            genv.LOCK_UNTRACKED_LABEL.TextColor3 = Color3.fromRGB(100, 170, 255)
        end
    end
end

