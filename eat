--======================================================
-- ANIMATION NAME CACHE
--======================================================
local ANIM_CACHE = {}
for _, obj in ipairs(AnimFolder:GetDescendants()) do
	if obj:IsA("Animation") then
		local id = tostring(obj.AnimationId or ""):match("%d+")
		if id then ANIM_CACHE[id] = obj.Name end
	end
end

local function getAnimName(id)
    -- Prefer cached name
    local cached = ANIM_CACHE[id]
    if cached and cached ~= "" then return cached end

    -- Search players for Animation instances (e.g., tools or backpack scripts)
    for _, pl in ipairs(Players:GetPlayers()) do
        for _, desc in ipairs(pl:GetDescendants()) do
            if desc:IsA("Animation") then
                local aid = tostring(desc.AnimationId or ""):match("%d+")
                if aid == tostring(id) then
                    if desc.Parent then return desc.Parent.Name end
                end
            end
        end
    end

    return ANIM_CACHE[id] or "Unknown"
end


