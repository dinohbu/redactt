-- 🔓 AUTO-UNLOCK WATCHDOG (TARGET OR YOU DIE)
--======================================================
task.spawn(function()
    while task.wait(0.25) do
        
        local target = getgenv().CURRENT_LOCKED_PLAYER
        if not target then continue end

        -- 1) Target removed
        if not target.Parent then
            notify("Auto Unlock", "Target removed")
            fullUnlockCleanup()
            continue
        end

        -- 2) Target humanoid died
        local hum = target:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health <= 0 then
            fullUnlockCleanup()
            notify("Auto Unlock", "Target died")
            continue
        end

        -- 3) YOU died
        local lp = game:GetService("Players").LocalPlayer
        if lp.Character then
            local myHum = lp.Character:FindFirstChildWhichIsA("Humanoid")
            if not myHum or myHum.Health <= 0 then
                fullUnlockCleanup()
                notify("Auto Unlock", "You died")
                continue
            end
        end
    end
end)
